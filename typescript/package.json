{
    "name": "@scitrera/messaging-spec",
    "version": "1.1.0",
    "description": "Universal ChatMessage & ToolCall schema for the Scitrera AI platform.",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/scitrera/ecosystem-messaging-spec.git",
        "directory": "typescript"
    },
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./src/index.ts"
        }
    },
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "typescript": "^5.9.3",
        "vitest": "^4.1.4"
    },
    "engines": {
        "node": ">=18"
    },
    "publishConfig": {
        "access": "public"
    }
}
